# ─── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NEXTIT Technologies

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# ─── Backend API ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
API_SECRET_KEY=your-internal-api-secret

# ─── OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@nextit.tech

# ─── Analytics ──────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ─── Database (for Prisma) ──────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/nextit_db
DIRECT_URL=postgresql://postgres:password@localhost:5432/nextit_db
